@model TuitionCenter.Models.ViewModels.Admin.TeacherVM

@{
    ViewData["Title"] = "Add Teacher";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="admin-page">

    <div class="page-header">

        <div>

            <a asp-action="Index"
               class="back-link">

                <i class="bi bi-arrow-left"></i>
                Back to Teachers

            </a>

            <h1 class="mt-3">
                Add New Teacher
            </h1>

            <p>
                Create a new teacher account.
            </p>

        </div>

    </div>


    <div class="form-layout">

        <div class="content-card">

            <div class="content-card-header">

                <div>
                    <h3>Teacher Information</h3>
                    <p>Enter the teacher's account details.</p>
                </div>

            </div>


            <div class="form-content">

                <form asp-action="Create"
                      method="post">

                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly"
                         class="text-danger mb-3">
                    </div>


                    <div class="form-row">

                        <div class="form-group">

                            <label asp-for="FullName">
                                Full Name
                            </label>

                            <div class="input-wrapper">

                                <i class="bi bi-person"></i>

                                <input asp-for="FullName"
                                       placeholder="Enter full name" />

                            </div>

                            <span asp-validation-for="FullName"
                                  class="text-danger">
                            </span>

                        </div>


                        <div class="form-group">

                            <label asp-for="Email">
                                Email Address
                            </label>

                            <div class="input-wrapper">

                                <i class="bi bi-envelope"></i>

                                <input asp-for="Email"
                                       placeholder="teacher@example.com" />

                            </div>

                            <span asp-validation-for="Email"
                                  class="text-danger">
                            </span>

                        </div>

                    </div>


                    <div class="form-row">

                        <div class="form-group">

                            <label asp-for="Phone">
                                Phone Number
                            </label>

                            <div class="input-wrapper">

                                <i class="bi bi-telephone"></i>

                                <input asp-for="Phone"
                                       placeholder="Enter phone number" />

                            </div>

                            <span asp-validation-for="Phone"
                                  class="text-danger">
                            </span>

                        </div>


                        <div class="form-group">

                            <label asp-for="Password">
                                Temporary Password
                            </label>

                            <div class="input-wrapper">

                                <i class="bi bi-lock"></i>

                                <input asp-for="Password"
                                       type="password"
                                       placeholder="Create password" />

                            </div>

                            <span asp-validation-for="Password"
                                  class="text-danger">
                            </span>

                        </div>

                    </div>


                    <div class="form-info-box">

                        <i class="bi bi-info-circle"></i>

                        <div>

                            <strong>Teacher Account</strong>

                            <p>
                                Teachers cannot register themselves.
                                This account will be created and managed
                                by the administrator.
                            </p>

                        </div>

                    </div>


                    <div class="form-actions">

                        <a asp-action="Index"
                           class="btn-secondary-custom">

                            Cancel

                        </a>


                        <button type="submit"
                                class="btn-primary-custom">

                            <i class="bi bi-person-plus"></i>
                            Create Teacher

                        </button>

                    </div>

                </form>

            </div>

        </div>

    </div>

</div>


@section Scripts {

    @{
        await Html.RenderPartialAsync(
            "_ValidationScriptsPartial"
        );
    }

}