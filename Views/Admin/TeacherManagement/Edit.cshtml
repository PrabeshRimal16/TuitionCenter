@model TuitionCenter.Models.ViewModels.Admin.TeacherVM

@{
    ViewData["Title"] = "Edit Teacher";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="admin-page">

    <div class="page-header">

        <div>

            <a asp-action="Index"
               class="back-link">

                <i class="bi bi-arrow-left"></i>
                Back to Teachers

            </a>

            <h1 class="mt-3">
                Edit Teacher
            </h1>

            <p>
                Update teacher account information.
            </p>

        </div>

    </div>


    <div class="form-layout">

        <div class="content-card">

            <div class="content-card-header">

                <div class="edit-profile-header">

                    <div class="teacher-profile-avatar">

                        @Model.FullName
                        .Substring(0, 1)
                        .ToUpper()

                    </div>

                    <div>

                        <h3>
                            @Model.FullName
                        </h3>

                        <p>
                            Teacher ID: #@Model.UserId
                        </p>

                    </div>

                </div>

            </div>


            <div class="form-content">

                <form asp-action="Edit"
                      asp-route-id="@Model.UserId"
                      method="post">

                    @Html.AntiForgeryToken()

                    <input asp-for="UserId"
                           type="hidden" />


                    <div asp-validation-summary="ModelOnly"
                         class="text-danger mb-3">
                    </div>


                    <div class="form-row">

                        <div class="form-group">

                            <label asp-for="FullName">
                                Full Name
                            </label>

                            <div class="input-wrapper">

                                <i class="bi bi-person"></i>

                                <input asp-for="FullName" />

                            </div>

                            <span asp-validation-for="FullName"
                                  class="text-danger">
                            </span>

                        </div>


                        <div class="form-group">

                            <label asp-for="Email">
                                Email Address
                            </label>

                            <div class="input-wrapper">

                                <i class="bi bi-envelope"></i>

                                <input asp-for="Email" />

                            </div>

                            <span asp-validation-for="Email"
                                  class="text-danger">
                            </span>

                        </div>

                    </div>


                    <div class="form-row">

                        <div class="form-group">

                            <label asp-for="Phone">
                                Phone Number
                            </label>

                            <div class="input-wrapper">

                                <i class="bi bi-telephone"></i>

                                <input asp-for="Phone" />

                            </div>

                            <span asp-validation-for="Phone"
                                  class="text-danger">
                            </span>

                        </div>


                        <div class="form-group">

                            <label>
                                Account Status
                            </label>

                            <div class="status-toggle">

                                <label class="switch">

                                    <input asp-for="IsActive"
                                           type="checkbox" />

                                    <span class="slider"></span>

                                </label>

                                <span>
                                    @(Model.IsActive
                                        ? "Active Account"
                                        : "Inactive Account")
                                </span>

                            </div>

                        </div>

                    </div>


                    <div class="form-actions">

                        <a asp-action="Index"
                           class="btn-secondary-custom">

                            Cancel

                        </a>


                        <button type="submit"
                                class="btn-primary-custom">

                            <i class="bi bi-check-lg"></i>
                            Save Changes

                        </button>

                    </div>

                </form>

            </div>

        </div>

    </div>

</div>


@section Scripts {

    @{
        await Html.RenderPartialAsync(
            "_ValidationScriptsPartial"
        );
    }

}