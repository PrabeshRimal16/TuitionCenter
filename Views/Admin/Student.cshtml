@{
    ViewData["Title"] = "Students";
    Layout = "_AdminLayout";
}

<div class="students-page">

    <!-- ===== Statistics Cards ===== -->
    <div class="stats-grid">

        <div class="stat-card">
            <div class="stat-header">
                <div class="icon blue"><i class="bi bi-people"></i></div>
                <span class="positive">+12%</span>
            </div>
            <p>Total Students</p>
            <h2>2,482</h2>
        </div>

        <div class="stat-card">
            <div class="stat-header">
                <div class="icon purple"><i class="bi bi-calendar-check"></i></div>
                <span>Daily Avg</span>
            </div>
            <p>Avg Attendance</p>
            <h2>94.2%</h2>
        </div>

        <div class="stat-card">
            <div class="stat-header">
                <div class="icon violet"><i class="bi bi-cash-stack"></i></div>
                <span class="danger">!24 Pending</span>
            </div>
            <p>Fee Collection</p>
            <h2>88.5%</h2>
        </div>

        <div class="stat-card">
            <div class="stat-header">
                <div class="icon blue"><i class="bi bi-mortarboard"></i></div>
                <span>Active Now</span>
            </div>
            <p>New Enrollments</p>
            <h2>156</h2>
        </div>

    </div>

    <!-- ===== Toolbar ===== -->
    <div class="toolbar">

        <div class="toolbar-left">

            <div class="search-box">
                <i class="bi bi-search"></i>
                <input type="text" placeholder="Search by student name, ID or email..." />
            </div>

            <button class="btn btn-filter">
                <i class="bi bi-funnel"></i>
                Filters
            </button>

        </div>

        <div class="toolbar-right">

            <button class="btn btn-outline-primary">
                Export CSV
            </button>

            <button class="btn btn-primary">
                <i class="bi bi-person-plus"></i>
                Register New Student
            </button>

        </div>

    </div>

    <!-- ===== Student Table ===== -->
    <div class="table-card">

        <table class="students-table">

            <thead>
                <tr>
                    <th>Student ID</th>
                    <th>Student Name</th>
                    <th>Class Level</th>
                    <th>Enrolled Courses</th>
                    <th>Attendance</th>
                    <th>Payment Status</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>

                <tr>
                    <td><strong>#SP-2024-001</strong></td>

                    <td>
                        <div class="student-info">
                            <div class="avatar">JD</div>
                            <div>
                                <h6>James Dorian</h6>
                                <small>james.dorian@email.com</small>
                            </div>
                        </div>
                    </td>

                    <td>Class 10 (Science)</td>

                    <td>
                        <span class="course-badge">Physics</span>
                        <span class="course-badge">Math</span>
                        <span class="more">+2</span>
                    </td>

                    <td>
                        <div class="attendance">
                            <div class="progress">
                                <div class="progress-bar" style="width:92%"></div>
                            </div>
                            <small>92% Attended</small>
                        </div>
                    </td>

                    <td>
                        <span class="status paid">Paid</span>
                    </td>

                    <td>
                        <div class="actions">
                            <i class="bi bi-eye"></i>
                            <i class="bi bi-pencil"></i>
                            <i class="bi bi-three-dots-vertical"></i>
                        </div>
                    </td>
                </tr>

                <tr>
                    <td><strong>#SP-2024-042</strong></td>

                    <td>
                        <div class="student-info">
                            <img src="https://i.pravatar.cc/60?img=5" class="avatar-img" />
                            <div>
                                <h6>Elena Vance</h6>
                                <small>e.vance@uni-edu.com</small>
                            </div>
                        </div>
                    </td>

                    <td>Bachelor (CS)</td>

                    <td>
                        <span class="course-badge">Algorithms</span>
                        <span class="course-badge">Web Dev</span>
                    </td>

                    <td>
                        <div class="attendance">
                            <div class="progress">
                                <div class="progress-bar" style="width:78%"></div>
                            </div>
                            <small>78% Attended</small>
                        </div>
                    </td>

                    <td>
                        <span class="status pending">Pending</span>
                    </td>

                    <td>
                        <div class="actions">
                            <i class="bi bi-eye"></i>
                            <i class="bi bi-pencil"></i>
                            <i class="bi bi-three-dots-vertical"></i>
                        </div>
                    </td>
                </tr>

                <tr>
                    <td><strong>#SP-2024-118</strong></td>

                    <td>
                        <div class="student-info">
                            <img src="https://i.pravatar.cc/60?img=15" class="avatar-img" />
                            <div>
                                <h6>Marcus Thorne</h6>
                                <small>m.thorne@edu-mail.org</small>
                            </div>
                        </div>
                    </td>

                    <td>Class 12 (Comm)</td>

                    <td>
                        <span class="course-badge">Accounting</span>
                        <span class="course-badge">Economics</span>
                    </td>

                    <td>
                        <div class="attendance">
                            <div class="progress">
                                <div class="progress-bar low" style="width:45%"></div>
                            </div>
                            <small class="danger">45% Low Attendance</small>
                        </div>
                    </td>

                    <td>
                        <span class="status failed">Failed</span>
                    </td>

                    <td>
                        <div class="actions">
                            <i class="bi bi-eye"></i>
                            <i class="bi bi-pencil"></i>
                            <i class="bi bi-three-dots-vertical"></i>
                        </div>
                    </td>
                </tr>

            </tbody>

        </table>

        <!-- ===== Pagination ===== -->
        <div class="table-footer">

            <span>Showing 1 to 10 of 2,482 entries</span>

            <div class="pagination">
                <button><i class="bi bi-chevron-left"></i></button>
                <button class="active">1</button>
                <button>2</button>
                <button>3</button>
                <span>...</span>
                <button>249</button>
                <button><i class="bi bi-chevron-right"></i></button>
            </div>

        </div>

    </div>

</div>