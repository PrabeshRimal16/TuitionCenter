@model List<TuitionCenter.Models.ViewModels.Admin.StudentVM>

@{
    ViewData["Title"] = "Student Management";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header">

    <div>
        <h1>Students</h1>
        <p>Manage all registered students</p>
    </div>
</div>


@if (TempData["Success"] != null)
{
    <div class="alert alert-success">

        <i class="bi bi-check-circle"></i>

        @TempData["Success"]

    </div>
}


<div class="card shadow-sm">

    <div class="card-body">

        <div class="table-responsive">

            <table class="table align-middle">

                <thead>

                    <tr>

                        <th>Student</th>

                        <th>Email</th>

                        <th>Phone</th>

                        <th>Enrollments</th>

                        <th>Status</th>

                        <th>Actions</th>

                    </tr>

                </thead>

                <tbody>

                    @if (!Model.Any())
                    {
                        <tr>

                            <td colspan="6"
                                class="text-center py-5">

                                No students found.

                            </td>

                        </tr>
                    }
                    else
                    {
                        foreach (var student in Model)
                        {
                            <tr>

                                <td>

                                    <strong>
                                        @student.FullName
                                    </strong>

                                </td>

                                <td>
                                    @student.Email
                                </td>

                                <td>
                                    @(student.Phone ?? "Not provided")
                                </td>

                                <td>

                                    <span class="badge bg-info">
                                        @student.EnrollmentCount
                                    </span>

                                </td>

                                <td>

                                    @if (student.IsActive)
                                    {
                                        <span class="badge bg-success">
                                            Active
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">
                                            Inactive
                                        </span>
                                    }

                                </td>

                                <td>

                                    <div class="btn-group">

                                        <a asp-controller="StudentManagement"
                                           asp-action="Details"
                                           asp-route-id="@student.UserId"
                                           class="btn btn-sm btn-outline-info">

                                            <i class="bi bi-eye"></i>

                                        </a>


                                        <a asp-controller="StudentManagement"
                                           asp-action="Edit"
                                           asp-route-id="@student.UserId"
                                           class="btn btn-sm btn-outline-primary">

                                            <i class="bi bi-pencil"></i>

                                        </a>


                                        <form asp-controller="StudentManagement"
                                              asp-action="ToggleActive"
                                              asp-route-id="@student.UserId"
                                              method="post"
                                              class="d-inline">

                                            @Html.AntiForgeryToken()

                                            <button type="submit"
                                                    class="btn btn-sm btn-outline-warning">

                                                <i class="bi bi-power"></i>

                                            </button>

                                        </form>

                                    </div>

                                </td>

                            </tr>
                        }
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>