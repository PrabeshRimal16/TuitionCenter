@model TuitionCenter.Models.ViewModels.Admin.StudentVM

@{
    ViewData["Title"] = "Student Details";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header">

    <div>

        <h1>Student Details</h1>

        <p>View student account and enrollment information</p>

    </div>


    <a asp-action="Edit"
       asp-controller="StudentManagement"
       asp-route-id="@Model.UserId"
       class="btn btn-primary">

        <i class="bi bi-pencil"></i>
        Edit Student

    </a>

</div>


<div class="row">

    <div class="col-md-4">

        <div class="card shadow-sm">

            <div class="card-body text-center">

                <div class="student-avatar">

                    @Model.FullName.Substring(0, 1).ToUpper()

                </div>


                <h4 class="mt-3">
                    @Model.FullName
                </h4>


                <p class="text-muted">
                    @Model.Email
                </p>


                @if (Model.IsActive)
                {
                    <span class="badge bg-success">
                        Active
                    </span>
                }
                else
                {
                    <span class="badge bg-danger">
                        Inactive
                    </span>
                }

            </div>

        </div>

    </div>


    <div class="col-md-8">

        <div class="card shadow-sm">

            <div class="card-body">

                <h5 class="mb-4">
                    Personal Information
                </h5>


                <div class="row">

                    <div class="col-md-6 mb-3">

                        <strong>Full Name</strong>

                        <p>
                            @Model.FullName
                        </p>

                    </div>


                    <div class="col-md-6 mb-3">

                        <strong>Email</strong>

                        <p>
                            @Model.Email
                        </p>

                    </div>


                    <div class="col-md-6 mb-3">

                        <strong>Phone</strong>

                        <p>
                            @(Model.Phone ?? "Not provided")
                        </p>

                    </div>


                    <div class="col-md-6 mb-3">

                        <strong>Created Date</strong>

                        <p>
                            @(Model.CreatedDate?.ToString("dd MMM yyyy")
                                ?? "Not available")
                        </p>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>


<div class="card shadow-sm mt-4">

    <div class="card-body">

        <h5 class="mb-4">

            Enrollments

            <span class="badge bg-primary">
                @Model.Enrollments.Count
            </span>

        </h5>


        @if (!Model.Enrollments.Any())
        {
            <div class="text-center py-4">

                <i class="bi bi-book fs-1 text-muted"></i>

                <p class="text-muted mt-2">
                    This student has no enrollments.
                </p>

            </div>
        }
        else
        {
            <div class="table-responsive">

                <table class="table">

                    <thead>

                        <tr>

                            <th>Class</th>

                            <th>Subject</th>

                            <th>Course Type</th>

                            <th>Status</th>

                            <th>Payment</th>

                        </tr>

                    </thead>


                    <tbody>

                        @foreach (var enrollment in Model.Enrollments)
                        {
                            <tr>

                                <td>
                                    @enrollment.ClassName
                                </td>

                                <td>
                                    @enrollment.SubjectName
                                </td>

                                <td>
                                    @enrollment.CourseType
                                </td>

                                <td>
                                    @enrollment.EnrollmentStatus
                                </td>

                                <td>
                                    @enrollment.PaymentStatus
                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>
        }

    </div>

</div>