@{
    Layout = null;
    ViewData["Title"] = "Teacher Dashboard";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Study Point</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                    },
                    colors: {
                        primary: '#0B4799',
                        secondary: '#4F81C7',
                        background: '#F9FAFB',
                        cardBg: '#F3F6FA',
                        textMain: '#1F2937',
                        textMuted: '#6B7280',
                        accentGreen: '#34D399',
                        successGreen: '#E6F4EA',
                        successText: '#1E8E3E'
                    }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #F9FAFB; }
    </style>
</head>
<body class="flex h-screen overflow-hidden">
    <!-- Sidebar -->
    <aside class="w-64 bg-white border-r border-gray-200 flex flex-col">
        <div class="p-6">
            <h1 class="text-2xl font-bold text-primary">Study <span class="text-secondary">Point</span></h1>
            <p class="text-xs text-gray-500 mt-1">Teacher Portal</p>
        </div>
        <nav class="flex-1 mt-4">
            <ul class="space-y-1">
                <li>
                    <a href="#" class="flex items-center px-6 py-3 text-primary bg-[#EBF3FF] border-l-4 border-primary font-medium">
                        <i class="fas fa-th-large w-5 h-5 mr-3 text-lg"></i>
                        Dashboard
                    </a>
                </li>
                <li>
                    <a href="#" class="flex items-center px-6 py-3 text-gray-600 hover:bg-gray-50 hover:text-primary transition-colors">
                        <i class="fas fa-users w-5 h-5 mr-3 text-lg"></i>
                        Class Management
                    </a>
                </li>
                <li>
                    <a href="#" class="flex items-center px-6 py-3 text-gray-600 hover:bg-gray-50 hover:text-primary transition-colors">
                        <i class="far fa-calendar-alt w-5 h-5 mr-3 text-lg"></i>
                        Schedule
                    </a>
                </li>
                <li>
                    <a href="#" class="flex items-center px-6 py-3 text-gray-600 hover:bg-gray-50 hover:text-primary transition-colors">
                        <i class="fas fa-video w-5 h-5 mr-3 text-lg"></i>
                        Live Classes
                    </a>
                </li>
                <li>
                    <a href="#" class="flex items-center px-6 py-3 text-gray-600 hover:bg-gray-50 hover:text-primary transition-colors">
                        <i class="far fa-user w-5 h-5 mr-3 text-lg"></i>
                        Profile
                    </a>
                </li>
            </ul>
        </nav>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 flex flex-col overflow-hidden">
        <!-- Top Navbar -->
        <header class="bg-white border-b border-gray-200 px-8 py-4 flex justify-between items-center">
            <div>
                <h2 class="text-xl font-bold text-gray-900">Dashboard</h2>
                <p class="text-sm text-gray-500">Here's what's happening with your classes today</p>
            </div>
            <div class="flex items-center space-x-6">
                <button class="text-gray-500 hover:text-gray-700 relative">
                    <i class="far fa-bell text-xl"></i>
                    <span class="absolute top-0 right-0 w-2 h-2 bg-red-500 rounded-full"></span>
                </button>
                <img src="https://i.pravatar.cc/150?img=11" alt="Profile" class="w-10 h-10 rounded-full border-2 border-primary object-cover" />
            </div>
        </header>

        <!-- Scrollable Content -->
        <div class="flex-1 overflow-y-auto p-8">
            <!-- Greeting Section -->
            <div class="flex justify-between items-end mb-8">
                <div>
                    <h1 class="text-3xl font-bold text-gray-900 mb-1">Good Morning, Mr. Kumar</h1>
                    <p class="text-gray-500">You have 4 classes scheduled for today.</p>
                </div>
                <div class="text-right">
                    <p class="text-xs text-gray-500 font-semibold tracking-wider uppercase mb-1">Academic Year</p>
                    <p class="text-xl font-bold text-gray-900">2025-2026</p>
                </div>
            </div>

            <!-- Top Cards Section -->
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-10">
                <!-- Main Feature Card -->
                <div class="lg:col-span-2 bg-white rounded-xl shadow-sm border border-gray-100 p-8 relative overflow-hidden flex flex-col justify-between" style="min-height: 280px;">
                    <!-- Decorative Background -->
                    <div class="absolute right-0 top-0 h-full w-1/2 opacity-10 pointer-events-none" style="background-image: url('data:image/svg+xml,%3Csvg width=\'100%25\' height=\'100%25\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cpath d=\'M10,10 L50,50 M50,10 L10,50\' stroke=\'%230B4799\' stroke-width=\'2\' fill=\'none\'/%3E%3C/svg%3E'); background-size: cover;"></div>
                    
                    <div>
                        <span class="inline-block bg-[#68E387] text-white text-xs font-bold px-3 py-1 rounded-full mb-4">STARTING IN 12 MINS</span>
                        <h2 class="text-3xl font-bold text-gray-900 mb-2">Accountancy (Grade 12)</h2>
                        <p class="text-gray-500 text-sm">Online Session &bull; Batch A &bull; 42 Enrolled Students</p>
                    </div>

                    <div class="flex items-center gap-6 mt-8">
                        <div class="flex -space-x-3">
                            <img src="https://i.pravatar.cc/100?img=1" class="w-10 h-10 rounded-full border-2 border-white" />
                            <img src="https://i.pravatar.cc/100?img=2" class="w-10 h-10 rounded-full border-2 border-white" />
                            <img src="https://i.pravatar.cc/100?img=3" class="w-10 h-10 rounded-full border-2 border-white" />
                            <div class="w-10 h-10 rounded-full border-2 border-white bg-[#EBF3FF] flex items-center justify-center text-primary font-medium text-sm">+39</div>
                        </div>
                        <button class="bg-[#0B4799] hover:bg-blue-800 text-white px-6 py-2.5 rounded-lg font-medium transition-colors flex items-center">
                            Share Class Link <i class="fas fa-arrow-right ml-2"></i>
                        </button>
                        <a href="#" class="text-[#0B4799] font-medium hover:underline">View Attendance List</a>
                    </div>
                </div>

                <!-- Stats Cards -->
                <div class="space-y-4">
                    <!-- Stat 1 -->
                    <div class="bg-[#F8F9FC] rounded-xl p-5 flex items-center gap-4">
                        <div class="w-12 h-12 rounded-full bg-[#EBF3FF] flex items-center justify-center text-[#0B4799]">
                            <i class="fas fa-user-friends text-xl"></i>
                        </div>
                        <div>
                            <p class="text-xs text-gray-500 font-semibold tracking-wider">TOTAL STUDENTS</p>
                            <div class="flex items-baseline gap-2">
                                <h3 class="text-2xl font-bold text-gray-900">1,248</h3>
                            </div>
                            <p class="text-xs text-[#22C55E] mt-0.5"><i class="fas fa-arrow-up mr-1"></i>4% from last month</p>
                        </div>
                    </div>

                    <!-- Stat 2 -->
                    <div class="bg-[#F8F9FC] rounded-xl p-5 flex items-center gap-4">
                        <div class="w-12 h-12 rounded-full bg-[#E6F4EA] flex items-center justify-center text-[#1E8E3E]">
                            <i class="fas fa-graduation-cap text-xl"></i>
                        </div>
                        <div>
                            <p class="text-xs text-gray-500 font-semibold tracking-wider">ACTIVE CLASSES</p>
                            <h3 class="text-2xl font-bold text-gray-900">8</h3>
                            <p class="text-xs text-gray-500 mt-0.5">Across 2 Departments</p>
                        </div>
                    </div>

                    <!-- Stat 3 -->
                    <div class="bg-[#F8F9FC] rounded-xl p-5 flex items-center gap-4">
                        <div class="w-12 h-12 rounded-full bg-[#E5E7EB] flex items-center justify-center text-gray-600">
                            <i class="fas fa-chart-bar text-xl"></i>
                        </div>
                        <div>
                            <p class="text-xs text-gray-500 font-semibold tracking-wider">AVG. ATTENDANCE</p>
                            <h3 class="text-2xl font-bold text-gray-900">94.2%</h3>
                            <p class="text-xs text-[#0B4799] mt-0.5">Stable performance</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Upcoming Classes Section -->
            <div class="mb-4 flex justify-between items-center">
                <h2 class="text-xl font-bold text-gray-900">Upcoming Classes Today</h2>
                <a href="#" class="text-[#0B4799] font-medium hover:underline text-sm flex items-center">Full Schedule <i class="fas fa-chevron-right text-xs ml-1"></i></a>
            </div>

            <div class="space-y-4">
                <!-- Class 1 -->
                <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 flex items-center justify-between">
                    <div class="flex items-center gap-6">
                        <div class="text-center w-20 border-r border-gray-100 pr-4">
                            <div class="text-[#0B4799] font-semibold text-lg leading-tight">12:30<br>PM</div>
                            <div class="text-xs text-gray-500 mt-1">60 mins</div>
                        </div>
                        <div>
                            <h3 class="text-lg font-bold text-gray-900">Introduction to Econometrics</h3>
                            <p class="text-sm text-gray-500 mt-1">Lecture Hall A &bull; Year 2 &bull; Course ID: ECO201</p>
                        </div>
                    </div>
                    <button class="text-gray-400 hover:text-gray-600 p-2">
                        <i class="fas fa-ellipsis-v"></i>
                    </button>
                </div>

                <!-- Class 2 -->
                <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 flex items-center justify-between">
                    <div class="flex items-center gap-6">
                        <div class="text-center w-20 border-r border-gray-100 pr-4">
                            <div class="text-[#0B4799] font-semibold text-lg leading-tight">02:00<br>PM</div>
                            <div class="text-xs text-gray-500 mt-1">90 mins</div>
                        </div>
                        <div>
                            <h3 class="text-lg font-bold text-gray-900">Global Markets Seminar</h3>
                            <p class="text-sm text-gray-500 mt-1">Room 402 &bull; Post-Graduate &bull; Course ID: ECO550</p>
                        </div>
                    </div>
                    <button class="text-gray-400 hover:text-gray-600 p-2">
                        <i class="fas fa-ellipsis-v"></i>
                    </button>
                </div>

                <!-- Class 3 -->
                <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 flex items-center justify-between">
                    <div class="flex items-center gap-6">
                        <div class="text-center w-20 border-r border-gray-100 pr-4">
                            <div class="text-[#0B4799] font-semibold text-lg leading-tight">04:30<br>PM</div>
                            <div class="text-xs text-gray-500 mt-1">45 mins</div>
                        </div>
                        <div>
                            <h3 class="text-lg font-bold text-gray-900">Office Hours - General Consult</h3>
                            <p class="text-sm text-gray-500 mt-1">Dr. Harrison's Office &bull; Open for all levels</p>
                        </div>
                    </div>
                    <button class="text-gray-400 hover:text-gray-600 p-2">
                        <i class="fas fa-ellipsis-v"></i>
                    </button>
                </div>
            </div>
        </div>
    </main>

    <script>
        // Simple script for interactivity could go here if needed.
    </script>
</body>
</html>