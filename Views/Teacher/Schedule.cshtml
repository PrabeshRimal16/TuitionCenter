@model TuitionCenter.Models.ViewModels.TeacherScheduleViewModel
@{
    Layout = null;
    ViewData["Title"] = "Teacher Schedule";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Study Point</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Inter', 'sans-serif'] },
                    colors: { primary: '#0B4799', secondary: '#4F81C7', background: '#F9FAFB' }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #F9FAFB; }
    </style>
</head>
<body class="flex h-screen overflow-hidden">
    <!-- Sidebar -->
    <aside class="w-64 bg-white border-r border-gray-200 flex flex-col">
        <div class="p-6">
            <h1 class="text-2xl font-bold text-primary">Study <span class="text-secondary">Point</span></h1>
            <p class="text-xs text-gray-500 mt-1">Teacher Portal</p>
        </div>
        <nav class="flex-1 mt-4">
            <ul class="space-y-1">
                <li>
                    <a href="@Url.Action("Dashboard", "Teacher")" class="flex items-center px-6 py-3 text-gray-600 hover:bg-gray-50 hover:text-primary transition-colors">
                        <i class="fas fa-th-large w-5 h-5 mr-3 text-lg"></i> Dashboard
                    </a>
                </li>
                <li>
                    <a href="#" class="flex items-center px-6 py-3 text-gray-600 hover:bg-gray-50 hover:text-primary transition-colors">
                        <i class="fas fa-users w-5 h-5 mr-3 text-lg"></i> Class Management
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Schedule", "Teacher")" class="flex items-center px-6 py-3 text-primary bg-[#EBF3FF] border-l-4 border-primary font-medium">
                        <i class="far fa-calendar-alt w-5 h-5 mr-3 text-lg"></i> Schedule
                    </a>
                </li>
                <li>
                    <a href="#" class="flex items-center px-6 py-3 text-gray-600 hover:bg-gray-50 hover:text-primary transition-colors">
                        <i class="fas fa-video w-5 h-5 mr-3 text-lg"></i> Live Classes
                    </a>
                </li>
                <li>
                    <a href="#" class="flex items-center px-6 py-3 text-gray-600 hover:bg-gray-50 hover:text-primary transition-colors">
                        <i class="far fa-user w-5 h-5 mr-3 text-lg"></i> Profile
                    </a>
                </li>
            </ul>
        </nav>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 flex flex-col overflow-hidden">
        <!-- Top Navbar -->
        <header class="bg-white border-b border-gray-200 px-8 py-4 flex justify-between items-center">
            <div>
                <h2 class="text-xl font-bold text-gray-900">Schedule</h2>
                <p class="text-sm text-gray-500">Your weekly teaching calendar</p>
            </div>
            <div class="flex items-center space-x-6">
                <button class="text-gray-500 hover:text-gray-700 relative">
                    <i class="far fa-bell text-xl"></i>
                    <span class="absolute top-0 right-0 w-2 h-2 bg-red-500 rounded-full"></span>
                </button>
                <div class="relative">
                    <img id="topProfileBtn" src="https://i.pravatar.cc/150?img=11" alt="Profile" class="w-10 h-10 rounded-full border-2 border-primary object-cover cursor-pointer hover:ring-2 hover:ring-primary hover:ring-offset-2 transition-all" />
                    <!-- Dropdown Menu -->
                    <div id="topProfileDropdown" class="hidden absolute right-0 mt-2 w-48 bg-white rounded-xl shadow-lg border border-gray-100 py-2 z-50">
                        <div class="px-4 py-3 border-b border-gray-100">
                            <p class="text-sm font-semibold text-gray-900">@Model.TeacherName</p>
                            <p class="text-xs text-gray-500 truncate">@Model.TeacherEmail</p>
                        </div>
                        <a href="#" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 hover:text-primary transition-colors">
                            <i class="far fa-user w-4 mr-2"></i> My Profile
                        </a>
                        <div class="border-t border-gray-100 my-1"></div>
                        <a href="@Url.Action("Logout", "Account")" class="block px-4 py-2 text-sm text-red-600 hover:bg-red-50 transition-colors">
                            <i class="fas fa-sign-out-alt w-4 mr-2"></i> Logout
                        </a>
                    </div>
                </div>
            </div>
        </header>

        <!-- Scrollable Content -->
        <div class="flex-1 overflow-y-auto p-8">
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
                <!-- Header with Navigation and Add Button -->
                <div class="flex justify-between items-center mb-6">
                    <div class="flex items-center space-x-4">
                        <div class="flex items-center border border-gray-200 rounded-lg overflow-hidden">
                            <a href="@Url.Action("Schedule", "Teacher", new { startDate = Model.CurrentWeekStart.AddDays(-7).ToString("yyyy-MM-dd") })" class="px-3 py-2 text-gray-500 hover:bg-gray-50 hover:text-primary transition-colors border-r border-gray-200">
                                <i class="fas fa-chevron-left text-sm"></i>
                            </a>
                            <a href="@Url.Action("Schedule", "Teacher", new { startDate = Model.CurrentWeekStart.AddDays(7).ToString("yyyy-MM-dd") })" class="px-3 py-2 text-gray-500 hover:bg-gray-50 hover:text-primary transition-colors">
                                <i class="fas fa-chevron-right text-sm"></i>
                            </a>
                        </div>
                        <h3 class="text-lg font-bold text-gray-900">@Model.WeekDateRangeDisplay</h3>
                    </div>
                    <button class="bg-[#0B4799] hover:bg-blue-800 text-white px-5 py-2.5 rounded-lg font-medium transition-colors flex items-center shadow-sm">
                        <i class="fas fa-plus mr-2"></i> Add Class
                    </button>
                </div>

                <!-- Calendar Grid -->
                <div class="grid grid-cols-7 border-t border-l border-gray-100 rounded-lg overflow-hidden">
                    <!-- Column Headers -->
                    @foreach (var day in Model.Days)
                    {
                        <div class="text-center py-4 border-r border-b border-gray-100 @(day.IsToday ? "bg-blue-50" : "bg-white")">
                            <p class="text-xs font-semibold text-gray-500 tracking-wider">@day.DayOfWeek</p>
                            <p class="text-2xl font-bold @(day.IsToday ? "text-primary" : "text-gray-900") mt-1">@day.DayOfMonth</p>
                        </div>
                    }

                    <!-- Grid Cells for Sessions -->
                    @foreach (var day in Model.Days)
                    {
                        <div class="border-r border-b border-gray-100 p-2 min-h-[500px] @(day.IsToday ? "bg-blue-50/30" : "bg-white")">
                            <div class="space-y-3">
                                @foreach (var session in day.Sessions)
                                {
                                    <div class="@session.ColorTheme rounded-lg p-3 shadow-sm hover:shadow-md transition-shadow cursor-pointer">
                                        <h4 class="font-bold text-sm leading-tight mb-1">@session.SubjectName - @session.ClassName</h4>
                                        <p class="text-xs opacity-90">@session.StartTime.ToString("h:mm") - @session.EndTime.ToString("h:mm tt")</p>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </main>

    <script>
        const topProfileBtn = document.getElementById('topProfileBtn');
        const topProfileDropdown = document.getElementById('topProfileDropdown');
        if (topProfileBtn) {
            topProfileBtn.addEventListener('click', function(e) {
                e.preventDefault();
                e.stopPropagation();
                topProfileDropdown.classList.toggle('hidden');
            });
            document.addEventListener('click', function(e) {
                if (!topProfileBtn.contains(e.target) && !topProfileDropdown.contains(e.target)) {
                    topProfileDropdown.classList.add('hidden');
                }
            });
        }
    </script>
</body>
</html>
