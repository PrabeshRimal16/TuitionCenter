<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Teacher Portal</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">

    <style>

            body {
                margin: 0;
                font-family: "Segoe UI", sans-serif;
                background: #f5f7fb;
            }

            /* ================= Sidebar ================= */

            .sidebar {
                width: 280px;
                height: 100vh;
                position: fixed;
                left: 0;
                top: 0;
                background: #fff;
                border-right: 1px solid #e5e7eb;
            }

            .logo {
                padding: 35px 30px;
            }

                .logo h2 {
                    color: #0056c7;
                    font-weight: 700;
                    font-size: 42px;
                    margin-bottom: 0;
                }

                .logo span {
                    color: #003e96;
                }

                .logo p {
                    color: #666;
                    font-size: 22px;
                    margin-top: 5px;
                }

            .menu {
                list-style: none;
                padding: 0;
                margin-top: 15px;
            }

                .menu li {
                    margin-bottom: 8px;
                }

                    .menu li a {
                        display: flex;
                        align-items: center;
                        gap: 18px;
                        padding: 18px 30px;
                        text-decoration: none;
                        color: #555;
                        font-size: 22px;
                        transition: .3s;
                    }

                    .menu li.active a {
                        background: #edf3ff;
                        color: #0056c7;
                        border-left: 5px solid #0056c7;
                        font-weight: 600;
                    }

                    .menu li a:hover {
                        background: #f5f8ff;
                        color: #0056c7;
                    }

                .menu i {
                    font-size: 24px;
                }

            /* ================= Main ================= */

            .main {
                margin-left: 280px;
            }

            /* ================= Navbar ================= */

            .navbar-custom {
                height: 95px;
                background: white;
                border-bottom: 1px solid #e5e7eb;
                display: flex;
                justify-content: space-between;
                align-items: center;
                padding: 0 45px;
            }

                .navbar-custom h2 {
                    font-weight: 700;
                    margin: 0;
                }

                .navbar-custom p {
                    margin: 0;
                    color: gray;
                }

            .right-menu {
                display: flex;
                align-items: center;
                gap: 25px;
            }

            .notification {
                font-size: 28px;
                cursor: pointer;
            }

            .profile {
                width: 55px;
                height: 55px;
                border-radius: 50%;
                border: 3px solid #0056c7;
            }

            .content {
                padding: 30px;
            }

    </style>

</head>

<body>

    <!-- Sidebar -->

    <aside class="sidebar">

        <div class="logo">

            <h2>Study <span>Point</span></h2>

            <p>Teacher Portal</p>

        </div>

        <ul class="menu">

            <li class="active">
                <a asp-controller="Teacher" asp-action="Dashboard">
                    <i class="bi bi-grid"></i>
                    Dashboard
                </a>
            </li>

            <li>
                <a asp-controller="Teacher" asp-action="Classes">
                    <i class="bi bi-people"></i>
                    Class Management
                </a>
            </li>

            <li>
                <a asp-controller="Teacher" asp-action="Schedule">
                    <i class="bi bi-calendar3"></i>
                    Schedule
                </a>
            </li>

            <li>
                <a asp-controller="Teacher" asp-action="LiveClasses">
                    <i class="bi bi-camera-video"></i>
                    Live Classes
                </a>
            </li>

            <li>
                <a asp-controller="Teacher" asp-action="Students">
                    <i class="bi bi-mortarboard"></i>
                    Students
                </a>
            </li>

            <li>
                <a asp-controller="Teacher" asp-action="Attendance">
                    <i class="bi bi-clipboard-check"></i>
                    Attendance
                </a>
            </li>

            <li>
                <a asp-controller="Teacher" asp-action="Assignments">
                    <i class="bi bi-journal-text"></i>
                    Assignments
                </a>
            </li>

            <li>
                <a asp-controller="Teacher" asp-action="Profile">
                    <i class="bi bi-person-circle"></i>
                    Profile
                </a>
            </li>

        </ul>

    </aside>

    <!-- Main -->

    <div class="main">

        <!-- Navbar -->

        <nav class="navbar-custom">

            <div>

                <h2>Dashboard</h2>

                <p>Here's what's happening with your classes today</p>

            </div>

            <div class="right-menu">

                <i class="bi bi-bell notification"></i>

                <img src="https://i.pravatar.cc/150?img=12"
                     class="profile"
                     alt="Teacher">

            </div>

        </nav>

        <!-- Page Content -->

        <div class="content">

            @RenderBody()

        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>