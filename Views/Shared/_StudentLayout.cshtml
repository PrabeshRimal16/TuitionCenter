<!DOCTYPE html>
<html lang="en">
<link rel="stylesheet" href="~/css/Student/student.css" asp-append-version="true" />
<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Student Portal</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <!-- Your CSS -->
    <link rel="stylesheet"
          href="~/css/Student/student.css"
          asp-append-version="true" />

    <link rel="stylesheet"
          href="~/css/Student/pricing.css"
          asp-append-version="true" />



</head>

<body>

    <aside class="sidebar">

        <!-- Logo -->
        <div class="logo">
            <h2>Study <span>Point</span></h2>
        </div>

        <hr class="sidebar-divider" />

        <!-- Progress -->
        <div class="progress-title">
            Enrollment Progress
        </div>

        <ul class="menu">

            <li>
                <a href="#">
                    <i class="bi bi-mortarboard"></i>
                    <span>Class</span>
                </a>
            </li>

            <li>
                <a href="#">
                    <i class="bi bi-grid-3x3-gap"></i>
                    <span>Subject</span>
                </a>
            </li>

            <li>
                <a href="#">
                    <i class="bi bi-card-list"></i>
                    <span>Intake</span>
                </a>
            </li>

            <li class="active">
                <a href="#">
                    <i class="bi bi-credit-card"></i>
                    <span>Pricing</span>
                </a>
            </li>

            <li>
                <a href="#">
                    <i class="bi bi-clock"></i>
                    <span>Timing</span>
                </a>
            </li>

            <li>
                <a href="#">
                    <i class="bi bi-bag"></i>
                    <span>Payments</span>
                </a>
            </li>

        </ul>

        <div class="back-button">

            <button class="btn-back">

                <i class="bi bi-arrow-left"></i>

                Back

            </button>

        </div>

    </aside>

    <!-- ================= Main ================= -->

    <div class="main-content">

        <!-- ================= Navbar ================= -->

        <nav class="top-navbar">

            <h2 class="page-title">Dashboard</h2>

            <div class="search-box">

                <i class="bi bi-search"></i>

                <input type="text"
                       placeholder="Search Courses or material..." />

            </div>

            <div class="right-menu">

                <button class="icon-btn">
                    <i class="bi bi-bell"></i>
                </button>

                <img src="https://i.pravatar.cc/100?img=15"
                     class="profile-img"
                     alt="Student">

            </div>

        </nav>

        <!-- ================= Content ================= -->

        <main class="content">

            @RenderBody()

        </main>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>