<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Student Portal</title>

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <link rel="stylesheet" href="~/css/Student/student.css" asp-append-version="true" />

</head>

<body>

    <!-- ================= Sidebar ================= -->

    <aside class="sidebar">

        <div class="logo">
            <h2>Study <span>Point</span></h2>
            <p>Student Portal</p>
        </div>

        <ul class="menu">

            <li class="active">
                <a asp-controller="Student" asp-action="Dashboard">
                    <i class="bi bi-grid"></i>
                    Dashboard
                </a>
            </li>

            <li>
                <a asp-controller="Student" asp-action="Courses">
                    <i class="bi bi-globe"></i>
                    Browse Courses
                </a>
            </li>

            <li>
                <a asp-controller="Student" asp-action="Schedule">
                    <i class="bi bi-clock-history"></i>
                    My Schedule
                </a>
            </li>

            <li>
                <a asp-controller="Student" asp-action="Assignments">
                    <i class="bi bi-journal-bookmark"></i>
                    Assignments
                </a>
            </li>

            <li>
                <a asp-controller="Student" asp-action="Attendance">
                    <i class="bi bi-calendar-check"></i>
                    Attendance
                </a>
            </li>

            <li>
                <a asp-controller="Student" asp-action="Payments">
                    <i class="bi bi-credit-card"></i>
                    Payments
                </a>
            </li>

            <li>
                <a asp-controller="Student" asp-action="Profile">
                    <i class="bi bi-person"></i>
                    Profile
                </a>
            </li>

        </ul>

    </aside>

    <!-- ================= Main ================= -->

    <div class="main-content">

        <!-- ================= Navbar ================= -->

        <nav class="top-navbar">

            <h2 class="page-title">Dashboard</h2>

            <div class="search-box">

                <i class="bi bi-search"></i>

                <input type="text"
                       placeholder="Search Courses or material..." />

            </div>

            <div class="right-menu">

                <button class="icon-btn">
                    <i class="bi bi-bell"></i>
                </button>

                <img src="https://i.pravatar.cc/100?img=15"
                     class="profile-img"
                     alt="Student">

            </div>

        </nav>

        <!-- ================= Content ================= -->

        <main class="content">

            @RenderBody()

        </main>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>