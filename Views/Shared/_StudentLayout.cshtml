<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1" />

    <title>@ViewData["Title"]</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <link rel="stylesheet"
          href="~/css/Student/student.css"
          asp-append-version="true" />

</head>

<body>

    <div class="layout">

        <aside class="sidebar">

            <div class="logo">

                <h2>

                    Study <span>Point</span>

                </h2>

            </div>

            <hr>

            <h6 class="progress-text">

                Enrollment Progress

            </h6>

            <ul class="step-menu">

                <li class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Class" ? "active" : "")">
                    <a asp-controller="Student" asp-action="Class">
                        <i class="bi bi-mortarboard"></i>
                        <span>Class</span>
                    </a>
                </li>

                <li class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Subject" ? "active" : "")">
                    <a asp-controller="Student" asp-action="Subject">
                        <i class="bi bi-grid"></i>
                        <span>Subject</span>
                    </a>
                </li>

                <li class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Intake" ? "active" : "")">
                    <a asp-controller="Student" asp-action="Intake">
                        <i class="bi bi-card-list"></i>
                        <span>Intake</span>
                    </a>
                </li>

                <li class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Pricing" ? "active" : "")">
                    <a asp-controller="Student" asp-action="Pricing">
                        <i class="bi bi-credit-card"></i>
                        <span>Pricing</span>
                    </a>
                </li>

                <li class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Timing" ? "active" : "")">
                    <a asp-controller="Student" asp-action="Timing">
                        <i class="bi bi-clock"></i>
                        <span>Timing</span>
                    </a>
                </li>

                <li class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Payments" ? "active" : "")">
                    <a asp-controller="Student" asp-action="Payments">
                        <i class="bi bi-wallet2"></i>
                        <span>Payments</span>
                    </a>
                </li>

            </ul>

            <button class="back-btn">

                <i class="bi bi-arrow-left"></i>

                Back

            </button>

        </aside>

        <div class="right-panel">

            <header class="topbar">

                <div class="brand">

                    Study Point

                </div>

                <div class="icons">

                    <i class="bi bi-question-circle"></i>

                    <i class="bi bi-person-circle"></i>

                </div>

            </header>

            <main>

                @RenderBody()

            </main>

        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>